{
  "name": "opensquad-content-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch --env-file=../.env server/index.ts\" \"vite\"",
    "dev:server": "tsx watch --env-file=../.env server/index.ts",
    "dev:client": "vite",
    "build": "vite build && npx playwright install chromium",
    "typecheck": "tsc -b",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "express": "^5.1.0",
    "googleapis": "^144.0.0",
    "playwright-core": "^1.58.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
